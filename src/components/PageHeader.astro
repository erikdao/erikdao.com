---
interface Props {
  title: string;
  summary?: string;
}

const { title, summary } = Astro.props;
---

<section class="flex flex-col justify-center pa-4">
  <div class="hero__inner flex flex-col pt-8 pb-12">
    <h1 class="text-7xl leading-none mb-6 order-2 font-serif font-medium">{title}</h1>
    {summary && (
      <div class="text-2xl font-light leading-snug order-3">
        <p class="m-0">{summary}</p>
      </div>
    )}
  </div>
</section>
