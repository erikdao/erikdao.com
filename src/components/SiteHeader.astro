---
import navigation from '../data/navigation.json';

interface NavItem {
  text: string;
  url: string;
  order: string;
}

const currentPath = Astro.url.pathname;
const navItems = navigation.items as NavItem[];

function isActiveLink(itemUrl: string, pageUrl: string): boolean {
  return itemUrl === pageUrl || (itemUrl.length > 1 && pageUrl.startsWith(itemUrl));
}
---

<header class="header py-12" role="banner">
  <div class="flex items-center justify-between mx-auto w-11/12 sm:w-10/12 max-w-screen-xl">
    <a href="/" class="flex items-center" rel="home" aria-label="Go To Homepage">
      <img src="/images/icons/pride_avatar_100.png" alt="Erik Dao" class="rounded-full mr-2" width="48" height="48">
      <span class="font-bold text-base">Erik Dao</span>
    </a>

    <div class="hidden md:flex items-center">
      <nav class="flex items-center" role="navigation" tabindex="-1">
        <div class="nav__content">
          <ul id="nav-menu" class="flex p-0 m-0 list-none">
            {navItems.map((item) => (
              <li class="relative">
                <a
                  href={item.url}
                  class="flex items-top relative lowercase py-2 px-3"
                  {...(item.url === currentPath ? { 'aria-current': 'page' } : {})}
                  {...(item.url.length > 1 && currentPath.startsWith(item.url) ? { 'data-state': 'active' } : {})}
                >
                  <span class="block mr-2 font-bold" aria-hidden="true">{item.order}</span>
                  {isActiveLink(item.url, currentPath) ? (
                    <span class="border-b-4 border-bach-orange-100 text-bach-orange-600 bg-bach-orange-100">{item.text}</span>
                  ) : (
                    <span class="border-b-4 border-bach-orange-100 text-bach-orange-600">{item.text}</span>
                  )}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </nav>
    </div>
  </div>
</header>
