---
interface PostItem {
  id: string;
  data: {
    title: string;
    date: string;
    summary: string;
  };
}

interface Props {
  posts: PostItem[];
  baseUrl: string;
}

const { posts, baseUrl } = Astro.props;

function formatDate(dateStr: string): string {
  const d = new Date(dateStr);
  return d.toLocaleDateString('en-GB', { day: '2-digit', month: 'long', year: 'numeric' });
}

function toISODate(dateStr: string): string {
  return new Date(dateStr).toISOString();
}
---

<div class="flex flex-col mb-20">
  <ul role="list" class="grid gap-8 grid-cols-1 sm:grid-cols-2">
    {posts.map((post) => (
      <li class="mt-8">
        <article>
          <time datetime={toISODate(post.data.date)}>{formatDate(post.data.date)}</time>
          <h3 class="text-bach-orange-600 text-2xl font-bold mt-2 mb-2">
            <a href={`${baseUrl}${post.id}/`} class="border-b-4 border-bach-orange-100 hover:bg-bach-orange-100 cursor-pointer pt-1">{post.data.title}</a>
          </h3>
          <p class="text-base text-gray-500">{post.data.summary}</p>
        </article>
      </li>
    ))}
  </ul>
</div>
